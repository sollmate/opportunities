ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
PROJECT_ROOT=./workspace

# LangSmith tracing (set TRACING=true to enable)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=opportunities

# Postgres for master-data lookup (tool reads crm.client keyed by client_id uuid)
# Example: postgresql://oppadmin:PASSWORD@psql-opportunities-dev.postgres.database.azure.com:5432/opportunities_poc?sslmode=require
DATABASE_URL=

# Microsoft Entra ID (Azure AD). Same app registration as the frontend/backend.
# Leave empty in local dev to disable token validation (the app starts without
# warming the JWKS cache); set both to enable JWT auth on /tax-advisory/*.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# App role a user must hold (access token `roles` claim) to call this API.
AZURE_REQUIRED_ROLE=opportunities.access

# Comma-separated origins allowed to call this API from a browser. Only needed
# when the frontend talks to the agent directly; ignored for server-to-server.
CORS_ORIGINS=http://localhost:3000
