# Comma-separated list of allowed CORS origins (the frontend dev server)
CORS_ORIGINS=http://localhost:3000

# Microsoft Entra ID (Azure AD) — directory (tenant) and application (client) IDs
# of the app registration. Incoming access tokens are validated against these.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# App role a user must be assigned (Entra "App roles") to access the application.
AZURE_REQUIRED_ROLE=opportunities.access
