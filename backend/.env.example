# Comma-separated list of allowed CORS origins (the frontend dev server)
CORS_ORIGINS=http://localhost:3000

# Microsoft Entra ID (Azure AD) — directory (tenant) and application (client) IDs
# of the app registration. Incoming access tokens are validated against these.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# App role a user must be assigned (Entra "App roles") to access the application.
AZURE_REQUIRED_ROLE=opportunities.access

# Base URL of the agent (reasoning) service. The browser never calls it
# directly — this backend proxies to it. Locally run the agent on a different
# port than this API (both default to 8000), e.g.:
#   cd agent && uv run uvicorn src.api.main:app --port 8001
AGENT_BASE_URL=http://localhost:8001

# ---------------------------------------------------------------------------
# PostgreSQL (Azure Database for PostgreSQL Flexible Server)
# Password-less: auth uses a Microsoft Entra token (managed identity in Azure,
# or your `az login` identity locally). There is intentionally NO password.
# Leave these empty to run the API without a database connection.
# ---------------------------------------------------------------------------
PG_HOST=psql-opportunities-dev.postgres.database.azure.com
PG_PORT=5432
PG_DATABASE=opportunities_poc

# Database role name = the identity that owns the Entra token, so this differs
# by environment:
#   - In Azure (container app):   PG_USER=ca-opportunities-agent-api  (the managed identity)
#   - Locally (your az login):    PG_USER=your-name@sollmate.eu       (the Entra admin)
PG_USER=

# Optional pool tuning
# PG_POOL_MAX_SIZE=10
# PG_COMMAND_TIMEOUT=30

# TLS is verified against the system trust store by default (works for Azure
# Postgres). Set this only to pin an explicit CA bundle.
# PG_SSL_ROOT_CERT=/path/to/ca.pem
