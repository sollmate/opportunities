# Base URL of the FastAPI backend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Auth.js (NextAuth) — base URL and a secret used to encrypt the session.
# Generate a secret with: npx auth secret  (or: openssl rand -base64 32)
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=

# Microsoft Entra ID app registration. ISSUER is the single-tenant authority,
# which restricts sign-in to members of your tenant.
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
